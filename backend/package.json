{
  "name": "finance-assistant-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "WhatsApp-based personal finance assistant backend (Baileys + Gemini + Supabase).",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon",
    "lint": "eslint src",
    "format": "prettier --write .",
    "test:unit": "node --test test/unit/*.test.js",
    "test:integration": "node --test test/integration/queries.test.js",
    "test:golden": "node --test test/integration/aiExtraction.test.js",
    "test": "npm run test:unit",
    "pipeline": "node scripts/testPipeline.js",
    "extraction": "node scripts/testExtraction.js",
    "persona": "node scripts/testPersona.js"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.9",
    "@supabase/supabase-js": "^2.45.4",
    "@google/genai": "^2.11.0",
    "node-cron": "^3.0.3",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "eslint": "^9.9.1",
    "prettier": "^3.3.3",
    "nodemon": "^3.1.4"
  }
}
