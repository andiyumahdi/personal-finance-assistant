# WhatsApp Cloud API (Meta) - see docs/whatsapp-cloud-api-setup.md
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# WhatsApp (Baileys) - DEPRECATED, kept only until the Cloud API path is
# confirmed stable in real use. Not read by index.js anymore.
WA_SESSION_PATH=./auth_state

# Server
PORT=3000

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini
GEMINI_API_KEY=
# Optional - if left blank, defaults to gemini-3.1-flash-lite (see src/ai/aiProvider.js).
# Chosen for free-tier headroom (15 RPM as of mid-2026) and stability. Google
# deprecates specific model names over time - if extraction/persona calls
# start returning 404 "model no longer available", check
# https://ai.google.dev/gemini-api/docs/models for the current lineup.
GEMINI_MODEL_EXTRACTION=
GEMINI_MODEL_PERSONA=

# App config
CONTEXT_WINDOW_MINUTES=3
TIMEZONE=Asia/Jakarta
# Used to build the magic link sent when a user types "dashboard"/"login"
# (see src/whatsapp/messageHandler.js handleDashboardLinkIntent). Local
# dev: http://localhost:3000  Production: your deployed frontend URL.
# Falls back to http://localhost:3000 if left blank.
DASHBOARD_BASE_URL=
