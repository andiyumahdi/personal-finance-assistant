NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Auth.js v5 (next-auth) primary secret var. Generate with:
#   npx auth secret
# or: openssl rand -base64 32
AUTH_SECRET=
# Optional in v5 (auto-detected from request headers in most cases), but
# setting it explicitly avoids surprises behind a proxy/load balancer.
# Local dev: http://localhost:3000  Production: your Vercel URL.
AUTH_URL=

# Backend-only, used solely by server-side code that needs elevated
# writes (e.g. account linking in auth.ts). Must never be prefixed
# NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
